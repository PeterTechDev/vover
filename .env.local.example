# ─── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string
# Get from: https://console.neon.tech → your project → "Connection Details" → Pooled connection
DATABASE_URL=postgresql://username:password@ep-xxx.aws-sa-east-1.neon.tech/vover?sslmode=require

# ─── NextAuth (Auth.js v5) ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Magic link email provider — get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender address (must be a verified domain in Resend)
EMAIL_FROM=Vover <noreply@vover.app>

# ─── Google OAuth (Optional) ─────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── TMDB API ─────────────────────────────────────────────────────────────────
# Get from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key
NEXT_PUBLIC_TMDB_API_KEY=your-tmdb-api-key

# ─── Setup Instructions ───────────────────────────────────────────────────────
# 1. Create a Neon project:
#    npx neonctl auth
#    npx neonctl projects create --name vover --region-id aws-sa-east-1
#    npx neonctl connection-string --project-name vover
#
# 2. Run database migrations:
#    npm run db:generate
#    npm run db:migrate
#
# 3. Generate NEXTAUTH_SECRET:
#    openssl rand -base64 32
#
# 4. Set up Resend:
#    - Create account at https://resend.com
#    - Add and verify your domain
#    - Create an API key
#
# 5. (Optional) Set up Google OAuth:
#    - Go to https://console.cloud.google.com
#    - Create OAuth 2.0 credentials
#    - Add http://localhost:3000/api/auth/callback/google as authorized redirect URI
